
Enum "address_address_type_enum" {
  "DELIVERY"
  "BILLING"
  "BOTH"
}

Enum "seller_address_address_type_enum" {
  "STORE"
  "WAREHOUSE"
  "FISCAL"
}

Enum "orders_order_status_enum" {
  "CREATED"
  "PAID"
  "PROCESSING"
  "SHIPPED"
  "DELIVERED"
  "CANCELLED"
}

Enum "order_address_address_type_enum" {
  "DELIVERY"
  "BILLING"
}

Enum "order_status_history_order_status_enum" {
  "CREATED"
  "PAID"
  "PROCESSING"
  "SHIPPED"
  "DELIVERED"
  "CANCELLED"
}

Enum "payment_payment_status_enum" {
  "PENDING"
  "PAID"
  "FAILED"
  "REFUNDED"
}

Enum "charge_payment_method_enum" {
  "CREDIT_CARD"
  "PIX"
  "BOLETO"
}

Enum "charge_charge_status_enum" {
  "PENDING"
  "AUTHORIZED"
  "PAID"
  "FAILED"
}

Enum "charge_status_history_charge_status_enum" {
  "PENDING"
  "AUTHORIZED"
  "PAID"
  "FAILED"
}

Enum "settlement_settlement_status_enum" {
  "PENDING"
  "SETTLED"
  "FAILED"
}

Enum "fee_rule_fee_type_enum" {
  "PERCENTAGE"
  "FIXED"
}

Enum "payout_payout_status_enum" {
  "PENDING"
  "PAID"
  "FAILED"
}

Table "user" {
  "user_id" INT [pk, not null, increment, note: 'Unique identifier for the user']
  "email" VARCHAR(100) [not null, note: 'Unique email address for authentication']
  "password_hash" VARCHAR(255) [not null, note: 'Secure hash of the user password']
  "phone_number" VARCHAR(20) [note: 'Contact phone number']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']
  "deleted_at" TIMESTAMP [note: 'Timestamp for soft delete']

  Indexes {
    email [unique, name: "uq_user_email"]
  }
  Note: 'Users in the marketplace'
}

Table "customer" {
  "customer_id" INT [pk, not null, note: 'FK to user.user_id']
  "full_name" VARCHAR(100) [not null, note: 'Customer full legal name']
  "cpf" CHAR(11) [not null, note: 'Brazilian Individual Taxpayer Registry ID (numbers only)']
  "birth_date" DATE [note: 'Date of birth for age validation']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']
  "deleted_at" TIMESTAMP [note: 'Timestamp for soft delete']

  Indexes {
    cpf [unique, name: "uq_customer_cpf"]
  }
  Note: 'Customers in the marketplace'
}

Table "seller" {
  "seller_id" INT [pk, not null, note: 'FK to user.user_id']
  "legal_name" VARCHAR(150) [not null, note: 'Official registered business name']
  "trade_name" VARCHAR(100) [note: 'Public-facing store name']
  "cnpj" CHAR(14) [not null, note: 'Brazilian Corporate Taxpayer Registry ID']
  "average_rating" DECIMAL(3,2) [not null, default: 0.00, note: 'Aggregated rating from 0.00 to 5.00']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']
  "deleted_at" TIMESTAMP [note: 'Timestamp for soft delete']

  Checks {
    `average_rating BETWEEN 0 AND 5` [name: 'ck_seller_rating']
  }

  Indexes {
    cnpj [unique, name: "uq_seller_cnpj"]
  }
  Note: 'Sellers in the marketplace'
}

Table "address" {
  "address_id" INT [pk, not null, increment, note: 'Unique identifier for the address']
  "customer_id" INT [not null, note: 'FK to the customer this address belongs to']
  "address_type" address_address_type_enum [not null, default: 'BOTH', note: 'Type of address: delivery, billing or both']
  "street" VARCHAR(200) [not null, note: 'Street name of the address']
  "street_number" VARCHAR(10) [not null, note: 'Street number of the address']
  "complement" VARCHAR(60) [note: 'Additional address information (apartment, suite, etc.)']
  "neighborhood" VARCHAR(80) [not null, note: 'Neighborhood of the address']
  "city" VARCHAR(80) [not null, note: 'City of the address']
  "state" CHAR(2) [not null, note: 'State of the address']
  "postal_code" CHAR(8) [not null, note: 'Postal code of the address']
  "country" CHAR(3) [not null, default: 'BRA', note: 'Country of the address']
  "is_default" BOOLEAN [not null, default: FALSE, note: 'Indicates if this is the default address for the customer']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']
  "deleted_at" TIMESTAMP [note: 'Timestamp for soft delete']

  Indexes {
    customer_id [name: "idx_address_customer"]
  }
  Note: 'Billing and delivery addresses linked to a customer'
}

Table "seller_address" {
  "seller_address_id" INT [pk, not null, increment, note: 'Unique identifier for the seller address']
  "seller_id" INT [not null, note: 'FK to the seller this address belongs to']
  "address_type" seller_address_address_type_enum [not null, default: 'STORE', note: 'Type of address: store front, warehouse, or fiscal']
  "street" VARCHAR(200) [not null, note: 'Street name of the address']
  "street_number" VARCHAR(10) [not null, note: 'Street number of the address']
  "complement" VARCHAR(60) [note: 'Additional address information (apartment, suite, etc.)']
  "neighborhood" VARCHAR(80) [not null, note: 'Neighborhood of the address']
  "city" VARCHAR(80) [not null, note: 'City of the address']
  "state" CHAR(2) [not null, note: 'State of the address']
  "postal_code" CHAR(8) [not null, note: 'Postal code of the address']
  "country" CHAR(3) [not null, default: 'BRA', note: 'Country of the address']
  "is_main" BOOLEAN [not null, default: FALSE, note: 'Indicates if this is the main address for the seller']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']
  "deleted_at" TIMESTAMP [note: 'Timestamp for soft delete']

  Indexes {
    seller_id [name: "idx_seller_address_seller"]
  }
  Note: 'Physical addresses for sellers (store, warehouse, fiscal)'
}

Table "product" {
  "product_id" INT [pk, not null, increment, note: 'Unique identifier for the product']
  "seller_id" INT [not null, note: 'FK to the seller who created the product']
  "product_name" VARCHAR(150) [not null, note: 'Name of the product']
  "product_description" TEXT [note: 'Description of the product']
  "is_active" BOOLEAN [not null, default: TRUE, note: 'Indicates if the product is active']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']
  "deleted_at" TIMESTAMP [note: 'Timestamp for soft delete']

  Indexes {
    seller_id [name: "idx_product_seller"]
    is_active [name: "idx_product_active"]
  }
  Note: 'Products created by sellers'
}

Table "product_variant" {
  "variant_id" INT [pk, not null, increment, note: 'Unique identifier for the product variant']
  "product_id" INT [not null, note: 'FK to the product this variant belongs to']
  "sku" VARCHAR(50) [not null, note: 'Stock Keeping Unit for the variant']
  "price" DECIMAL(10,2) [not null, note: 'Price of the variant']
  "stock_quantity" INT [not null, default: 0, note: 'Available quantity of the variant']
  "is_active" BOOLEAN [not null, default: TRUE, note: 'Indicates if the variant is active']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']
  "deleted_at" TIMESTAMP [note: 'Timestamp for soft delete']

  Checks {
    `price >= 0` [name: 'ck_price']
  }

  Indexes {
    sku [unique, name: "uq_sku"]
    product_id [name: "idx_variant_product"]
  }
  Note: 'Variants of products created by sellers (allows for different colors or products specifications)'
}

Table "category" {
  "category_id" INT [pk, not null, increment, note: 'Unique identifier for the category']
  "category_name" VARCHAR(100) [not null, note: 'Name of the category']
  "parent_id" INT [note: 'Self-referencing FK to parent category (NULL for top-level categories)']
  "deleted_at" TIMESTAMP [note: 'Timestamp for soft delete']
  Note: 'Product categories (hierarchical)'
}

Table "product_category" {
  "category_id" INT [not null, note: 'FK to category.category_id']
  "product_id" INT [not null, note: 'FK to product.product_id']

  Indexes {
    (product_id, category_id) [pk, name: "pk_product_category"]
  }
  Note: 'Join table for product <-> category relationship (N:N)'
}

Table "product_image" {
  "image_id" INT [pk, not null, increment, note: 'Unique identifier for the product image']
  "variant_id" INT [not null, note: 'FK to the product variant this image belongs to']
  "image_url" VARCHAR(255) [not null, note: 'URL of the product image']
  "is_primary" BOOLEAN [not null, default: FALSE, note: 'Indicates if this is the primary image for the variant']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  Note: 'Photos linked to a product'
}

Table "orders" {
  "order_id" INT [pk, not null, increment, note: 'Unique identifier for the order']
  "customer_id" INT [not null, note: 'FK to the customer who made the order']
  "delivery_address_id" INT [not null, note: 'FK to the delivery address for the order (address_id)']
  "order_status" orders_order_status_enum [not null, default: 'CREATED', note: 'Current status of the order']
  "total_amount" DECIMAL(10,2) [not null, note: 'Total amount of the order (calculated at checkout)']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']

  Indexes {
    customer_id [name: "idx_orders_customer"]
    order_status [name: "idx_orders_status"]
    created_at [name: "idx_orders_created_at"]
    delivery_address_id [name: "idx_orders_delivery_addr"]
  }
  Note: 'Represents an order made by a customer'
}

Table "order_item" {
  "order_item_id" INT [pk, not null, increment, note: 'Unique identifier for the order item']
  "order_id" INT [not null, note: 'FK to the order this item belongs to']
  "variant_id" INT [not null, note: 'FK to the product variant being purchased (snapshot of variant at purchase time)']
  "product_name" VARCHAR(150) [not null, note: 'snapshot: product name at purchase time']
  "sku" VARCHAR(50) [not null, note: 'snapshot: SKU of the variant at purchase time']
  "quantity" INT [not null, note: 'Quantity of this variant being purchased']
  "unit_price" DECIMAL(10,2) [not null, note: 'snapshot: unit price of the variant at purchase time']
  "total_price" DECIMAL(10,2) [not null, note: 'snapshot: total price for this item (quantity * unit_price) at purchase time']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']

  Checks {
    `quantity > 0` [name: 'ck_item_quantity']
    `unit_price >= 0` [name: 'ck_item_price']
  }

  Indexes {
    order_id [name: "idx_order_item_order"]
    variant_id [name: "idx_order_item_variant"]
  }
  Note: 'Items of an order references product_variant for full SKU/price snapshot'
}

Table "order_address" {
  "order_address_id" INT [pk, not null, increment, note: 'Unique identifier for the order address']
  "order_id" INT [not null, note: 'FK to the order this address belongs to']
  "address_type" order_address_address_type_enum [not null, note: 'Type of the address (delivery or billing)']
  "street" VARCHAR(200) [not null, note: 'Street name of the address']
  "street_number" VARCHAR(10) [not null, note: 'Street number of the address']
  "complement" VARCHAR(60) [note: 'Additional address information (apartment, suite, etc.)']
  "neighborhood" VARCHAR(80) [not null, note: 'Neighborhood of the address']
  "city" VARCHAR(80) [not null, note: 'City of the address']
  "state" CHAR(2) [not null, note: 'State of the address']
  "postal_code" CHAR(8) [not null, note: 'Postal code of the address']
  "country" CHAR(3) [not null, default: 'BRA', note: 'Country of the address']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  Note: 'Represents an order address - Dereferences address table'
}

Table "order_status_history" {
  "history_id" INT [pk, not null, increment, note: 'Unique identifier for the order status history record']
  "order_id" INT [not null, note: 'FK to the order this status change belongs to']
  "order_status" order_status_history_order_status_enum [not null, default: 'CREATED', note: 'Order status at the time of the change']
  "changed_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Timestamp when the order status was changed']
  Note: 'Contains the history of changes in order status'
}

Table "payment" {
  "payment_id" INT [pk, not null, increment, note: 'Unique identifier for the payment']
  "order_id" INT [not null, note: 'FK to the order this payment belongs to']
  "amount" DECIMAL(10,2) [not null, note: 'Payment amount']
  "payment_status" payment_payment_status_enum [not null, note: 'Current status of the payment']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']

  Indexes {
    order_id [name: "idx_payment_order"]
  }
  Note: 'Represents a payment linked to an order'
}

Table "charge" {
  "charge_id" INT [pk, not null, increment, note: 'Unique identifier for the charge attempt']
  "payment_id" INT [not null, note: 'FK to the payment this charge attempt belongs to']
  "amount" DECIMAL(10,2) [not null, note: 'Amount attempted to charge (may be equal or less than payment amount in case of installments)']
  "payment_method" charge_payment_method_enum [not null, note: 'Payment method used for the charge attempt']
  "charge_status" charge_charge_status_enum [not null, note: 'Current status of the charge attempt']
  "gateway_ref" VARCHAR(100) [note: 'Reference from the payment gateway for this charge attempt']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record last update timestamp']

  Indexes {
    payment_id [name: "idx_charge_payment"]
  }
  Note: 'Represents a charge attempt'
}

Table "charge_status_history" {
  "history_id" INT [pk, not null, increment, note: 'Unique identifier for the charge status history record']
  "charge_id" INT [not null, note: 'FK to the charge this status change belongs to']
  "charge_status" charge_status_history_charge_status_enum [not null, note: 'Charge status at the time of the change']
  "changed_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Timestamp when the charge status was changed']
  Note: 'Contains the history of charge_attempts'
}

Table "settlement" {
  "settlement_id" INT [pk, not null, increment, note: 'Unique identifier for the settlement']
  "charge_id" INT [not null, note: 'FK to the charge this settlement belongs to']
  "amount" DECIMAL(10,2) [not null, note: 'Amount settled (may be equal or less than charge amount in case of installments)']
  "installment" INT
  "settlement_status" settlement_settlement_status_enum [not null, note: 'Current status of the settlement']
  "settled_at" TIMESTAMP [note: 'Timestamp when the settlement was completed (NULL if pending)']

  Indexes {
    charge_id [name: "idx_settlement_charge"]
  }
  Note: 'Represents actual money settlement (supports installments)'
}

Table "fee_rule" {
  "fee_rule_id" INT [pk, not null, increment, note: 'Unique identifier for the fee rule']
  "fee_name" VARCHAR(100) [not null, note: 'Name of the fee rule']
  "fee_type" fee_rule_fee_type_enum [not null, note: 'Type of fee: percentage of the order amount or fixed value']
  "fee_value" DECIMAL(10,2) [not null, note: 'Value of the fee (percentage value or fixed amount depending on fee_type)']
  "min_amount" DECIMAL(10,2) [note: 'Minimum fee amount (used for percentage fees to ensure a minimum charge)']
  "max_amount" DECIMAL(10,2) [note: 'Maximum fee amount (used for percentage fees to limit the maximum charge)']
  "is_active" BOOLEAN [not null, default: TRUE, note: 'Indicates if the fee rule is active and should be applied to new orders']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  Note: 'Defines marketplace fee strategies'
}

Table "applied_fee" {
  "applied_fee_id" INT [pk, not null, increment, note: 'Unique identifier for the applied fee record']
  "charge_id" INT [not null, note: 'FK to the charge this fee was applied to']
  "fee_rule_id" INT [not null, note: 'FK to the fee rule that was applied']
  "amount" DECIMAL(10,2) [not null, note: 'Amount of the fee applied (calculated at charge time based on the fee rule and order amount)']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']

  Indexes {
    charge_id [name: "idx_applied_fee_charge"]
  }
  Note: 'Snapshot of fee applied at charge time'
}

Table "seller_balance" {
  "seller_id" INT [pk, not null, note: 'FK to the seller this balance belongs to']
  "balance" DECIMAL(10,2) [not null, default: 0.00, note: 'Current balance available to the seller']
  "updated_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Timestamp of the last balance update']

  Checks {
    `balance >= 0` [name: 'ck_balance']
  }
  Note: 'Tracks current balance available to seller'
}

Table "payout" {
  "payout_id" INT [pk, not null, increment, note: 'Unique identifier for the payout']
  "seller_id" INT [not null, note: 'FK to the seller receiving the payout']
  "amount" DECIMAL(10,2) [not null, note: 'Amount of the payout']
  "payout_status" payout_payout_status_enum [not null, note: 'Current status of the payout']
  "created_at" TIMESTAMP [not null, default: `CURRENT_TIMESTAMP`, note: 'Record creation timestamp']
  Note: 'Represents money transferred to seller'
}

Ref "fk_customer_user":"user"."user_id" < "customer"."customer_id" [delete: cascade]

Ref "fk_seller_user":"user"."user_id" < "seller"."seller_id" [delete: cascade]

Ref "fk_address_customer":"customer"."customer_id" < "address"."customer_id" [delete: cascade]

Ref "fk_seller_address_seller":"seller"."seller_id" < "seller_address"."seller_id" [delete: cascade]

Ref "fk_product_seller":"seller"."seller_id" < "product"."seller_id" [delete: cascade]

Ref "fk_variant_product":"product"."product_id" < "product_variant"."product_id" [delete: cascade]

Ref "fk_category_parent":"category"."category_id" < "category"."parent_id" [delete: set null]

Ref "fk_category":"category"."category_id" < "product_category"."category_id" [delete: cascade]

Ref "fk_product":"product"."product_id" < "product_category"."product_id" [delete: cascade]

Ref "fk_image_product":"product_variant"."variant_id" < "product_image"."variant_id" [delete: cascade]

Ref "fk_order_customer":"customer"."customer_id" < "orders"."customer_id"

Ref "fk_item_variant":"product_variant"."variant_id" < "order_item"."variant_id" [update: cascade, delete: restrict]

Ref "fk_item_order":"orders"."order_id" < "order_item"."order_id" [delete: cascade]

Ref "fk_order_address_order":"orders"."order_id" < "order_address"."order_id" [delete: cascade]

Ref "fk_history_order":"orders"."order_id" < "order_status_history"."order_id" [delete: cascade]

Ref "fk_payment_order":"orders"."order_id" < "payment"."order_id" [delete: cascade]

Ref "fk_charge_payment":"payment"."payment_id" < "charge"."payment_id" [delete: cascade]

Ref "fk_charge_history_charge":"charge"."charge_id" < "charge_status_history"."charge_id" [delete: cascade]

Ref "fk_settlement_charge":"charge"."charge_id" < "settlement"."charge_id" [delete: cascade]

Ref "fk_applied_fee_charge":"charge"."charge_id" < "applied_fee"."charge_id" [delete: cascade]

Ref "fk_applied_fee_rule":"fee_rule"."fee_rule_id" < "applied_fee"."fee_rule_id"

Ref "fk_balance_seller":"seller"."seller_id" < "seller_balance"."seller_id" [delete: cascade]

Ref "fk_payout_seller":"seller"."seller_id" < "payout"."seller_id"
